# ── Polymarket ───────────────────────────────────────────────────────────────
CONDITION_ID=0x...
SCAN_INTERVAL=10
ANALYSIS_ENDPOINT=http://self_improve:4000/analyze

# ── Anthropic (Engineer Agent + Analyst) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Self-Improvement Orchestrator ─────────────────────────────────────────────
WIN_RATE_THRESHOLD=0.55       # trigger patch if win rate drops below this
SELF_IMPROVE_INTERVAL=300     # check every N seconds (default: 5 min)

# ── Persistent storage (inside container) ─────────────────────────────────────
TRADES_FILE=/app/data/trades.json
PARAMS_FILE=/app/config/trade_params.json
SCANNER_SRC=/app/src/market_scanner.rb
